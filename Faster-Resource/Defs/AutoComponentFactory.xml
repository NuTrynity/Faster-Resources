<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>AutoComponentFactory</defName>
        <label>component assembly plant</label>
        <description>An industrial automation facility that produces Components, needs to be fueled
            with Steel</description>
        <graphicData>
            <texPath>Things/Building/Power/ChemfuelPoweredGenerator</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2,2)</drawSize>
            <shadowData>
                <volume>(1.93,1,1.69)</volume>
                <offset>(-0.03,0,-0.1)</offset>
            </shadowData>
        </graphicData>
        <size>(2,2)</size>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <designationCategory>Production</designationCategory>

        <tickerType>Normal</tickerType>

        <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <WorkToBuild>10000</WorkToBuild>
            <Flammability>0.5</Flammability>
        </statBases>
        <costList>
            <Steel>300</Steel>
            <ComponentIndustrial>12</ComponentIndustrial>
        </costList>
        <researchPrerequisites>
            <li>Machining</li>
        </researchPrerequisites>

        <comps>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>600</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable" />
            <li Class="CompProperties_Refuelable">
                <fuelCapacity>120.0</fuelCapacity>
                <fuelFilter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </fuelFilter>
                <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
                <consumeFuelOnlyWhenPowered>true</consumeFuelOnlyWhenPowered>
                <fuelLabel>Stored Steel</fuelLabel>
                <fuelGizmoLabel>Steel contents</fuelGizmoLabel>
                <fuelConsumptionRate>120.0</fuelConsumptionRate>
            </li>

            <li Class="FasterResource.FueledFactoryCompProperties">
                <thingToSpawn>ComponentIndustrial</thingToSpawn>
                <spawnCount>10</spawnCount>
                <spawnIntervalRange>25000</spawnIntervalRange>
                <requiresPower>true</requiresPower>
                <writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
            </li>
        </comps>
    </ThingDef>
</Defs>