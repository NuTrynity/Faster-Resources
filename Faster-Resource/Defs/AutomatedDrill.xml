<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>ElectricSteelMiner</defName>
        <label>electric steel miner</label>
        <description>An automated deep drill that power to independently extract refined steel. Does not require manual operation.</description>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <texPath>Things/Building/Production/DeepDrill</texPath>
            <drawSize>(2,2)</drawSize>
            <drawRotated>false</drawRotated>
        </graphicData>
        <size>(1,1)</size>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <fillPercent>0.5</fillPercent>
        <hasInteractionCell>false</hasInteractionCell>
        <designationCategory>Production</designationCategory>

        <tickerType>Normal</tickerType>

        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
        <minifiedDef>MinifiedThing</minifiedDef>
        <building>
            <uninstallWork>1800</uninstallWork>
            <buildingTags>
                <li>Production</li>
            </buildingTags>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>
        <costList>
            <Steel>200</Steel>
            <ComponentIndustrial>6</ComponentIndustrial>
        </costList>
        <researchPrerequisites>
            <li>DeepDrilling</li>
        </researchPrerequisites>
        <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <WorkToBuild>15000</WorkToBuild>
            <Flammability>0.3</Flammability>
            <Beauty>-30</Beauty>
            <Mass>45</Mass>
        </statBases>
        <comps>
            <li Class="CompProperties_Forbiddable" />
            <li Class="CompProperties_Flickable" />
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>300</basePowerConsumption>
            </li>
            <li Class="CompProperties_Spawner">
                <thingToSpawn>Steel</thingToSpawn>
                <spawnCount>100</spawnCount>
                <spawnIntervalRange>15000</spawnIntervalRange>
                <requiresPower>true</requiresPower>
                <writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
            </li>
            <li Class="CompProperties_CreatesInfestations" />
        </comps>
    </ThingDef>
</Defs>